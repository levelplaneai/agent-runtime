{
  "description": "Verify one feature: build context then call Gemini for spatial envelope analysis",
  "inputs": {
    "feature_name":      { "type": "string" },
    "output_dir":        { "type": "string" },
    "view_crops_json":   { "type": "string" },
    "dim_data_json":     { "type": "string" },
    "all_features_json": { "type": "string" }
  },
  "outputs": {
    "featureName":             { "from": "$.verify_prompt.output.featureName" },
    "correctedFeatureName":    { "from": "$.verify_prompt.output.correctedFeatureName" },
    "existsAsPhysicalFeature": { "from": "$.verify_prompt.output.existsAsPhysicalFeature" },
    "impactsEnvelope":         { "from": "$.verify_prompt.output.impactsEnvelope" },
    "associatedAxes":          { "from": "$.verify_prompt.output.associatedAxes" },
    "reasoning":               { "from": "$.verify_prompt.output.reasoning" },
    "new_features":            { "from": "$.verify_prompt.output.new_features" }
  },
  "entry": "get_feature_ctx",
  "nodes": {
    "get_feature_ctx": "get_feature_ctx@v1",
    "verify_prompt":   "verify_prompt@v1"
  },
  "edges": [
    { "from": "get_feature_ctx", "to": "verify_prompt" }
  ]
}
