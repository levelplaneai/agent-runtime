{
  "description": "Merges phase3 crops, phase4 dims, and phase5 verifications into the allFeatures structure, then splits into contributing and non-contributing feature subsets for phases 6 and 7.",
  "timeout_seconds": 30,
  "input_schema": {
    "type": "object",
    "properties": {
      "verifications": { "type": "string" },
      "all_features_json": { "type": "string" },
      "all_dims_json": { "type": "string" }
    },
    "required": ["verifications", "all_features_json", "all_dims_json"]
  },
  "output_schema": {
    "type": "object",
    "properties": {
      "contributing": { "type": "array", "items": { "type": "object" } },
      "non_contributing": { "type": "array", "items": { "type": "object" } },
      "all_features_built": { "type": "array", "items": { "type": "object" } }
    }
  }
}
