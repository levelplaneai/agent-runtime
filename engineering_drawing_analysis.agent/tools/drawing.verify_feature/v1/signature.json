{
  "description": "Calls the Gemini model with the exact TS-mirrored interleaved multimodal payload for phase5 spatial verification of one feature. Returns verification result plus any newly discovered features to append to the queue.",
  "timeout_seconds": 180,
  "input_schema": {
    "type": "object",
    "properties": {
      "feature_name": { "type": "string" },
      "all_features_json": { "type": "string" },
      "all_dims_json": { "type": "string" },
      "output_dir": { "type": "string" }
    },
    "required": ["feature_name", "all_features_json", "all_dims_json", "output_dir"]
  },
  "output_schema": {
    "type": "object",
    "properties": {
      "featureName": { "type": "string" },
      "correctedFeatureName": { "type": "string" },
      "existsAsPhysicalFeature": { "type": "boolean" },
      "impactsEnvelope": { "type": "string" },
      "associatedAxes": { "type": "array", "items": { "type": "string" } },
      "reasoning": { "type": "string" },
      "new_features": { "type": "array", "items": { "type": "string" }, "description": "Newly discovered feature names to add to the verification queue" }
    }
  }
}
