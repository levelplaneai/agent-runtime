{
  "type": "tool_call",
  "description": "Resolve view crops, dimension crops, and feature crop path for a single feature — pure data, no LLM",
  "inputs": {
    "feature_name":    { "from": "$.inputs.feature_name" },
    "output_dir":      { "from": "$.inputs.output_dir" },
    "view_crops_json": { "from": "$.inputs.view_crops_json" },
    "dim_data_json":   { "from": "$.inputs.dim_data_json" },
    "all_features_json": { "from": "$.inputs.all_features_json" }
  },
  "config": {
    "tool": "drawing.get_feature_context@v1",
    "args": {
      "feature_name":    "{{ feature_name }}",
      "output_dir":      "{{ output_dir }}",
      "view_crops_json": "{{ view_crops_json }}",
      "dim_data_json":   "{{ dim_data_json }}",
      "all_features_json": "{{ all_features_json }}"
    }
  },
  "output_schema": {
    "type": "object",
    "properties": {
      "feature_name": { "type": "string" },
      "view_crops": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "path": { "type": "string" }
          }
        }
      },
      "dims": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "text":    { "type": "string" },
            "callout": { "type": "string" },
            "details": { "type": "string" },
            "path":    { "type": "string" }
          }
        }
      },
      "feature_crop_path": { "type": "string" }
    }
  }
}
