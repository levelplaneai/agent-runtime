{
  "type": "tool_call",
  "description": "Build the reconciliation graph from phase8 spatial understanding data (pure computation, no LLM call)",
  "inputs": {
    "spatial_data": { "from": "$.map_phase8.output.items" },
    "output_dir": { "from": "$.inputs.output_dir" }
  },
  "config": {
    "tool": "drawing.reconciliation_graph@v1",
    "args": {
      "spatial_data": "{{ spatial_data }}",
      "output_dir": "{{ output_dir }}"
    }
  },
  "output_schema": {
    "type": "object",
    "properties": {
      "nodes": { "type": "array", "items": { "type": "object" } },
      "edges": { "type": "array", "items": { "type": "object" } }
    }
  }
}
