{
  "type": "tool_call",
  "description": "Crop feature bounding boxes from each view's cropped image, producing per-view feature crop paths for phase4",
  "inputs": {
    "views": { "from": "$.crop_views.output.views" },
    "phase3_results": { "from": "$.map_phase3.output.items" },
    "output_dir": { "from": "$.inputs.output_dir" }
  },
  "config": {
    "tool": "image.crop_features@v1",
    "args": {
      "views": "{{ views }}",
      "phase3_results": "{{ phase3_results }}",
      "output_dir": "{{ output_dir }}"
    }
  },
  "output_schema": {
    "type": "object",
    "properties": {
      "phase4_input": {
        "type": "array",
        "items": { "type": "object" }
      },
      "all_features_json": { "type": "string" },
      "non_geometric_views": { "type": "array", "items": { "type": "string" } }
    }
  }
}
