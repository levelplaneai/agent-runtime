{
  "type": "prompt",
  "description": "Create a high-level step-by-step plan for analysing this engineering drawing",
  "inputs": {
    "drawing": { "from": "$.inputs.drawing", "type": "file_path" }
  },
  "config": {
    "model": "gemini/gemini-2.5-pro",
    "max_tokens": 8192
  },
  "output_schema": {
    "type": "object",
    "properties": {
      "plan": { "type": "array", "items": { "type": "string" } }
    },
    "required": ["plan"]
  },
  "on_error": "retry:2"
}
