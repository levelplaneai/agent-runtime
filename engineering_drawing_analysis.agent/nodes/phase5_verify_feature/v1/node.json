{
  "type": "subflow",
  "description": "Verify one feature's spatial envelope contribution by running the phase5_verify subflow (context lookup + Gemini prompt)",
  "inputs": {
    "feature_name":      { "from": "$.feature" },
    "output_dir":        { "from": "$.inputs.output_dir" },
    "view_crops_json":   { "from": "$.crop_views.output.views" },
    "dim_data_json":     { "from": "$.crop_dims.output.dim_data_by_feature" },
    "all_features_json": { "from": "$.crop_features.output.all_features_json" }
  },
  "config": {
    "flow": "phase5_verify@v1"
  }
}
