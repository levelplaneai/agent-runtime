{
  "type": "prompt",
  "description": "Classify the drawing domain as Automotive, Aerospace, or Other and determine if it is in scope",
  "inputs": {
    "drawing": { "from": "$.inputs.drawing", "type": "file_path" },
    "title_block": { "from": "$.phase0a_title_block.output.text" }
  },
  "config": {
    "model": "anthropic/claude-sonnet-4-6"
  },
  "output_schema": {
    "type": "object",
    "properties": {
      "domain": { "type": "string", "enum": ["Automotive", "Aerospace", "Other"] },
      "confidence": { "type": "integer" },
      "in_scope": { "type": "boolean" },
      "evidence": { "type": "array", "items": { "type": "string" } },
      "out_of_scope_note": { "type": "string" }
    },
    "required": ["domain", "confidence", "in_scope", "evidence", "out_of_scope_note"]
  },
  "on_error": "retry:2"
}
