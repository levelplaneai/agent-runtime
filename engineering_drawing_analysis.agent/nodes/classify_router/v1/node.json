{
  "type": "router",
  "description": "Route to phase1_planning for process_operation drawings, or scope_error for all others",
  "inputs": {
    "routing": { "from": "$.phase0c_type.output.routing" }
  },
  "config": {
    "branches": [
      { "when": { "field": "routing", "op": "eq", "value": "process_operation" }, "goto": "phase1_planning" },
      { "default": true, "goto": "scope_error" }
    ]
  }
}
