{
  "type": "prompt",
  "description": "Classify the drawing type as process_part or assembly and determine the processing route",
  "inputs": {
    "drawing": { "from": "$.inputs.drawing", "type": "file_path" },
    "title_block": { "from": "$.phase0a_title_block.output.text" },
    "domain_result": { "from": "$.phase0b_domain.output" }
  },
  "config": {
    "model": "anthropic/claude-sonnet-4-6"
  },
  "output_schema": {
    "type": "object",
    "properties": {
      "drawing_type": { "type": "string", "enum": ["process_part", "assembly"] },
      "routing": { "type": "string", "enum": ["process_operation", "assembly_operation", "out_of_scope"] },
      "confidence": { "type": "integer" },
      "evidence": { "type": "array", "items": { "type": "string" } },
      "rationale": { "type": "string" }
    },
    "required": ["drawing_type", "routing", "confidence", "evidence", "rationale"]
  },
  "on_error": "retry:2"
}
